{
  "manifest_version": 3,
  "name": "Open Meeting Scribe",
  "short_name": "Meeting Scribe",
  "version": "1.1.0",
  "description": "Records Google Meet audio, streams a live transcript, and generates structured meeting notes using OpenAI. No backend required. Your API key, your data.",

  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab",
    "sidePanel"
  ],

  "host_permissions": [
    "https://meet.google.com/*"
  ],

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    },
    "default_title": "Open Meeting Scribe"
  },

  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
